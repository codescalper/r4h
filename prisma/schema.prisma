// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Admin ───────────────────────────────────────────────────────────────────

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String   @default("Admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  passwordResetTokens AdminPasswordResetToken[]
  posts               Post[]
  galleryImages       GalleryImage[]
  programs            Program[]
  sentMessages        Message[]
}

model AdminPasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Member ───────────────────────────────────────────────────────────────────

enum MemberStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum FitnessLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model Member {
  id String @id @default(cuid())

  // Personal Info
  firstName       String
  lastName        String
  email           String       @unique
  phone           String
  dateOfBirth     DateTime?
  gender          Gender
  city            String
  emergencyContact String?

  // Health Info
  height          Float?
  weight          Float?
  thighSize       Float?
  waistSize       Float?
  sleepHours      Float?
  fitnessLevel    FitnessLevel @default(BEGINNER)
  medicalConditions String?

  // Files (relative paths stored, served from /api/files/...)
  profilePhotoPath     String?

  // Auth
  password        String?
  status          MemberStatus @default(PENDING)

  // Preferences
  emailNotifications Boolean @default(false)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  passwordResetTokens   MemberPasswordResetToken[]
  setPasswordTokens     MemberSetPasswordToken[]
  donations             Donation[]
  healthRecords         HealthRecord[]
  posts                 Post[]
  medicalReports        MemberReport[]
  receivedMessages      Message[]
}

// ─── Member Medical Reports (history) ────────────────────────────────────────

model MemberReport {
  id        String   @id @default(cuid())
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  path      String
  filename  String
  size      Int
  uploadedAt DateTime @default(now())
}

// ─── Admin → Member Messages ──────────────────────────────────────────────────

enum MessageScope {
  PERSONAL
  BROADCAST
}

model Message {
  id        String       @id @default(cuid())
  subject   String
  body      String       @db.Text
  scope     MessageScope @default(PERSONAL)
  read      Boolean      @default(false)
  readAt    DateTime?

  adminId   String
  admin     Admin        @relation(fields: [adminId], references: [id], onDelete: Cascade)

  memberId  String
  member    Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)

  createdAt DateTime     @default(now())
}

model MemberPasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MemberSetPasswordToken {
  id        String   @id @default(cuid())
  token     String   @unique
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Health Records ──────────────────────────────────────────────────────────

model HealthRecord {
  id          String   @id @default(cuid())
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  weight      Float?
  height      Float?
  thighSize   Float?
  waistSize   Float?
  sleepHours  Float?
  notes       String?
  recordedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
}

// ─── Donations ───────────────────────────────────────────────────────────────

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  UPI
  CARD
  NET_BANKING
  CASH
  OTHER
}

model Donation {
  id            String         @id @default(cuid())
  donorName     String
  donorEmail    String
  donorPhone    String?
  amount        Float
  currency      String         @default("INR")
  paymentMethod PaymentMethod  @default(UPI)
  message       String?
  status        DonationStatus @default(PENDING)
  memberId      String?
  member        Member?        @relation(fields: [memberId], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// ─── Posts / News / Blog ─────────────────────────────────────────────────────

enum PostStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum PostAuthorType {
  ADMIN
  MEMBER
}

enum PostCategory {
  EVENT_RECAP
  HEALTH_TIPS
  COMMUNITY_STORY
  ANNOUNCEMENT
}

model Post {
  id             String         @id @default(cuid())
  title          String
  slug           String         @unique
  excerpt        String?
  content        String         @db.Text
  coverImagePath String?
  category       PostCategory   @default(ANNOUNCEMENT)
  status         PostStatus     @default(DRAFT)
  authorType     PostAuthorType @default(MEMBER)
  adminId        String?
  admin          Admin?         @relation(fields: [adminId], references: [id], onDelete: SetNull)
  memberId       String?
  member         Member?        @relation(fields: [memberId], references: [id], onDelete: SetNull)
  rejectionNote  String?
  publishedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  images         PostImage[]
}

model PostImage {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  path      String
  altText   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// ─── Gallery ──────────────────────────────────────────────────────────────────

model GalleryImage {
  id        String         @id @default(cuid())
  path      String
  altText   String?
  caption   String?
  adminId   String?
  admin     Admin?         @relation(fields: [adminId], references: [id], onDelete: SetNull)
  createdAt DateTime       @default(now())

  tags      GalleryTagsOnImages[]
}

model GalleryTag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  images    GalleryTagsOnImages[]
}

model GalleryTagsOnImages {
  imageId   String
  image     GalleryImage @relation(fields: [imageId], references: [id], onDelete: Cascade)
  tagId     String
  tag       GalleryTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([imageId, tagId])
}

// ─── Programs & Events ────────────────────────────────────────────────────────

enum ProgramCategory {
  MARATHON
  YOGA
  CAMP
  CORPORATE
  FUN_RUN
  OTHER
}

enum ProgramStatus {
  UPCOMING
  PAST
  CANCELLED
}

model Program {
  id             String          @id @default(cuid())
  title          String
  slug           String?         @unique
  excerpt        String?
  content        String          @db.Text
  coverImagePath String?
  date           DateTime?
  location       String?
  category       ProgramCategory @default(OTHER)
  status         ProgramStatus   @default(UPCOMING)
  adminId        String?
  admin          Admin?          @relation(fields: [adminId], references: [id], onDelete: SetNull)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

// ─── Contact Submissions ──────────────────────────────────────────────────────

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

